# Site config for sgpu-remote-bridge (copy to ~/.config/sgpu/bridge.env on
# the Grafana host — referenced by sgpu-master-bridge.service). Not in git:
# it names your internal hosts/accounts.
SGPU_BRIDGE_REMOTE=user@remote-master
#SGPU_BRIDGE_REMOTE_FILE=/tmp/slurm-gpu-tui/metrics.prom
#SGPU_BRIDGE_PREFIX=master_
#SGPU_BRIDGE_OUT=/tmp/slurm-gpu-tui/master_sgpu.prom
