[Unit]
Description=SLURM GPU Monitor Collector
After=network.target

[Service]
Type=simple
User=REPLACED_BY_INSTALLER
ExecStart=/home/jaemin/mgt/slurm-gpu-tui/.venv/bin/sgpu-collector
# "always" (not on-failure): site cron sweeps like pkill -f python send
# SIGTERM, the collector exits 0, and on-failure would leave it dead.
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
